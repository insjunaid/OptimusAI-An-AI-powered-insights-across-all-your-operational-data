# ═══════════════════════════════════════════════════════════
# AI-Powered Operations Intelligence Platform
# Environment Variables Template
# ═══════════════════════════════════════════════════════════
# Copy this file to backend/.env and fill in your values:
#   cp .env.example backend/.env
# ═══════════════════════════════════════════════════════════

# ─── Gemini AI (REQUIRED) ─────────────────────────────────
# Get your API key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash
GEMINI_EMBEDDING_MODEL=text-embedding-004

# ─── Database ─────────────────────────────────────────────
# Local dev: SQLite (no setup needed)
DATABASE_URL=sqlite:///./ops_intel.db
# Docker/Production: PostgreSQL
# DATABASE_URL=postgresql://ops_user:ops_secret_2024@localhost:5432/ops_intel

# ─── ChromaDB Vector Store ────────────────────────────────
CHROMA_PERSIST_DIR=./chroma_db

# ─── File Upload ──────────────────────────────────────────
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=50

# ─── Server ───────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]

# ─── Logging ──────────────────────────────────────────────
LOG_LEVEL=INFO

# ─── Docker Compose Only ─────────────────────────────────
POSTGRES_PASSWORD=ops_secret_2024
